<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AyuTok - Pro</title>
    <style>
        body { margin: 0; background: #000; color: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto; }
        .app { max-width: 450px; margin: 0 auto; min-height: 100vh; display: flex; flex-direction: column; }
        
        /* Header */
        .header { padding: 15px; font-size: 25px; font-weight: bold; border-bottom: 1px solid #222; text-align: center; }
        
        /* Video Feed */
        .feed { flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 10px; }
        iframe { width: 100%; height: 400px; border-radius: 12px; background: #111; }
        
        /* 10 Features Section */
        .grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; padding: 10px; background: #111; border-top: 1px solid #222; }
        .btn-feat { background: #222; color: #fff; border: none; padding: 10px 5px; border-radius: 8px; font-size: 10px; cursor: pointer; text-align: center; }
        .btn-feat:hover { background: #444; }

        /* Search Bar */
        .search-box { width: 90%; padding: 10px; border-radius: 20px; border: none; margin-bottom: 10px; }
    </style>
</head>
<body>

<div class="app">
    <div class="header">AyuTok</div>
    
    <div class="feed">
        <input type="text" id="link" class="search-box" placeholder="YouTube लिंक पेस्ट करें...">
        <button onclick="load()" style="padding: 10px 20px; border-radius: 20px; border: none; background: #ff4500; color: white;">चलाएं</button>
        <br>
        <iframe id="vid" src="https://www.youtube.com/embed/dQw4w9WgXcQ" frameborder="0" allowfullscreen></iframe>
    </div>

    <div class="grid">
        <button class="btn-feat" onclick="alert('1. Skill Mode: Active')">1. Skill</button>
        <button class="btn-feat" onclick="alert('2. Inner Circle: Open')">2. Circle</button>
        <button class="btn-feat" onclick="alert('3. Rewards: Earned')">3. Reward</button>
        <button class="btn-feat" onclick="alert('4. Focus Mode: ON')">4. Focus</button>
        <button class="btn-feat" onclick="alert('5. Collab: Ready')">5. Collab</button>
        <button class="btn-feat" onclick="alert('6. Audio Chat: On')">6. Audio</button>
        <button class="btn-feat" onclick="alert('7. Trend Badge: Get')">7. Badge</button>
        <button class="btn-feat" onclick="alert('8. Time Machine: Go')">8. Memory</button>
        <button class="btn-feat" onclick="alert('9. Feed Control: Set')">9. Control</button>
        <button class="btn-feat" onclick="alert('10. Support: Live')">10. Help</button>
    </div>
</div>

<script>
    function load() {
        let link = document.getElementById("link").value;
        let id = link.includes("v=") ? link.split('v=')[1].substring(0,11) : link.split('/').pop();
        document.getElementById("vid").src = "https://www.youtube.com/embed/" + id;
    }
</script>
</body>
</html>
